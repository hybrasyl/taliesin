{
  "name": "taliesin",
  "version": "2.2.0",
  "description": "Dark Ages client asset viewer — companion to Creidhne",
  "main": "./out/main/index.js",
  "author": "Caeldeth",
  "homepage": "https://github.com/hybrasyl/taliesin",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --build",
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "start": "electron-vite preview -- --trace-warnings",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:win:portable": "npm run build && electron-builder --win portable",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "fetch-xsd": "node scripts/downloadXSD.js"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@eriscorp/dalib-ts": "^1.0.1",
    "@eriscorp/hybindex-ts": "^0.2.0",
    "@fontsource/cinzel": "^5.2.8",
    "@fontsource/cinzel-decorative": "^5.2.8",
    "@fontsource/crimson-pro": "^5.2.8",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/archiver": "^7.0.0",
    "archiver": "^7.0.1",
    "music-metadata": "^11.12.3",
    "react-icons": "^5.6.0",
    "recoil": "^0.7.7",
    "simplex-noise": "^4.0.3",
    "unzipper": "^0.12.3",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@eslint/js": "^9.39.4",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/xml2js": "^0.4.14",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.0",
    "vite": "^6.4.1",
    "vitest": "^4.1.2"
  }
}
